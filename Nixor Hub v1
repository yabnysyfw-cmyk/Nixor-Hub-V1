-- 1. كود الترحيب المطور مع الصورة والخلفية المتحركة 🌈
local function WelcomePlayer()
    local p = game.Players.LocalPlayer
    local gui = Instance.new("ScreenGui", p.PlayerGui)
    gui.Name = "NixorWelcomeRainbow"
    gui.IgnoreGuiInset = true
    
    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 0.2
    
    -- إضافة صورتك الشخصية في منتصف الترحيب ✅
    local profileImg = Instance.new("ImageLabel", frame)
    profileImg.Size = UDim2.new(0, 200, 0, 200)
    profileImg.Position = UDim2.new(0.5, -100, 0.4, -100)
    profileImg.Image = "rbxthumb://type=Asset&id=111349449029153&w=420&h=420"
    profileImg.BackgroundTransparency = 1
    Instance.new("UICorner", profileImg).CornerRadius = UDim.new(1, 0) -- جعلها دائرية
    
    local text = Instance.new("TextLabel", frame)
    text.Size = UDim2.new(1, 0, 0, 50)
    text.Position = UDim2.new(0, 0, 0.7, 0)
    text.BackgroundTransparency = 1
    text.Text = "Nixor Hub | سكربت المطور نيكسور v1 👑"
    text.TextColor3 = Color3.new(1, 1, 1)
    text.TextSize = 35
    text.Font = Enum.Font.SourceSansBold
    text.ZIndex = 2

    task.spawn(function()
        local hue = 0
        while gui.Parent do
            hue = hue + 1/255
            if hue > 1 then hue = 0 end
            frame.BackgroundColor3 = Color3.fromHSV(hue, 0.7, 0.7)
            task.wait()
        end
    end)
    game:GetService("Debris"):AddItem(gui, 4)
end
WelcomePlayer()

